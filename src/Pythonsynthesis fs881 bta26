    def show_results_figure(self):
        """
        Builds a matplotlib figure showing a formatted results summary table.

        Uses is_safe() on peak temperature to get SAFE, WARNING, or UNSAFE status.
        Does not call plt.show() so both figures open together at end of script.
        """
        rows = []
        warning_messages = []

        for name, data in self.results_db.items():
            components = data["components"]
            max_temps = data["max_temperatures"]
            margins = data["thermal_margins"]
            stop_reason = data["stop_reason"]
            overtemp_time = data["overtemp_time"]

            for i in range(len(components)):
                comp = components[i]
                peak = max_temps[i]
                margin = margins[i]

                # call is_safe on peak temp so status matches what simulation used
                status = comp.is_safe(peak)

                # assign row colour based on status for visual clarity
                if status == "UNSAFE":
                    row_colour = "#ffcccc"
                elif status == "WARNING":
                    row_colour = "#fff3cc"
                    warning_messages.append(
                        f"{name}  |  {comp.name}: only {margin:.1f}C from limit, consider reducing duty cycle"
                    )
                else:
                    row_colour = "#ccffcc"

                rows.append([
                    name,
                    comp.name,
                    f"{peak:.2f} C",
                    f"{comp.max_temperature:.1f} C",
                    f"{margin:+.2f} C",
                    status,
                    row_colour
                ])

            # add a summary row showing stop reason for this scenario
            if stop_reason == "Completed":
                rows.append(["", f"Result: {stop_reason}", "", "", "", "", "#e8f4e8"])
            else:
                rows.append([
                    "",
                    f"Result: {stop_reason}  at t={overtemp_time:.1f}s",
                    "", "", "", "", "#fce8e8"
                ])

        num_rows = len(rows)
        num_warnings = len(warning_messages)

        # figure height grows with number of rows and warnings so nothing gets clipped
        fig_height = max(5, 0.5 * num_rows + 2.0 + 0.5 * num_warnings)
        fig = plt.figure(figsize=(13, fig_height))
        fig.patch.set_facecolor("#1e1e2e")

        ax = fig.add_subplot(111)
        ax.set_facecolor("#1e1e2e")
        ax.axis("off")

        bottom_margin = 0.08 + 0.04 * num_warnings
        fig.subplots_adjust(top=0.88, bottom=bottom_margin, left=0.02, right=0.98)

        fig.text(0.5, 0.95, "Thermal Simulation Results",
                 ha="center", va="top", fontsize=15, fontweight="bold", color="white")

        col_labels = ["Scenario", "Component", "Peak Temp", "Max Limit", "Margin", "Status"]
        cell_text = [[r[0], r[1], r[2], r[3], r[4], r[5]] for r in rows]
        cell_colours = [[r[6]] * 6 for r in rows]

        table = ax.table(cellText=cell_text, colLabels=col_labels,
                         cellColours=cell_colours, cellLoc="center", loc="center")

        table.auto_set_font_size(False)
        table.set_fontsize(10)
        table.scale(1, 1.6)

        for col in range(len(col_labels)):
            header_cell = table[0, col]
            header_cell.set_facecolor("#2d2d44")
            header_cell.set_text_props(color="white", fontweight="bold")

        for row_idx in range(1, num_rows + 1):
            for col_idx in range(len(col_labels)):
                cell = table[row_idx, col_idx]
                cell.set_text_props(color="#111111")
                cell.set_edgecolor("#aaaaaa")

        if warning_messages:
            fig.text(0.5, bottom_margin - 0.01, "Warnings:",
                     ha="center", va="top", fontsize=10, fontweight="bold", color="#ffcc00")
            for idx, msg in enumerate(warning_messages):
                fig.text(0.5, bottom_margin - 0.01 - 0.04 * (idx + 1),
                         f"  {msg}", ha="center", va="top", fontsize=9, color="#ffdd55")


